SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JITO_BUNDLE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_TIP_ACCOUNT=
JITO_TIP_LAMPORTS=10000

# Base58 secret key for main launcher wallet
MAIN_WALLET_PRIVATE_KEY=

# Comma separated base58 secret keys (bundle buy/sell wallets)
BUNDLE_PRIVATE_KEYS=

# BagsFM tx-builder API (or your proxy that returns serialized tx)
BAGSFM_API_BASE_URL=https://api.bags.fm
BAGSFM_LAUNCH_PATH=/v1/tx/launch
BAGSFM_BUY_PATH=/v1/tx/buy
BAGSFM_SELL_PATH=/v1/tx/sell
API_KEY=

# Bundle tuning
MAX_TXS_PER_BUNDLE=5
BUY_AMOUNT_SOL=0.05
SELL_PERCENTAGE=100